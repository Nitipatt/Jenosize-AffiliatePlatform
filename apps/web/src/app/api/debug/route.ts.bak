import { NextResponse } from 'next/server';

export async function GET() {
  const backendUrl = process.env.API_BACKEND_URL ?? 'NOT_SET';

  const results: Record<string, unknown> = {
    API_BACKEND_URL: backendUrl,
    timestamp: new Date().toISOString(),
  };

  // Try to reach the backend
  if (backendUrl !== 'NOT_SET') {
    try {
      const res = await fetch(`${backendUrl}/api/products`, {
        signal: AbortSignal.timeout(5000),
      });
      results.backendStatus = res.status;
      results.backendOk = res.ok;
      const body = await res.text();
      results.backendBodyPreview = body.slice(0, 200);
    } catch (err: unknown) {
      results.backendError = err instanceof Error ? err.message : String(err);
    }
  }

  return NextResponse.json(results);
}
